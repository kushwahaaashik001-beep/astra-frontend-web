---
// Layout settings
const { title = "Astra Troubleshoot Engine", description = "Technical Troubleshooting Manuals" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
		
		<style is:global>
			:root {
				--primary: #0066cc;
				--text-dark: #1a1a1a;
				--bg-light: #f4f7f6;
			}
			body {
				font-family: 'Inter', sans-serif;
				margin: 0;
				background: var(--bg-light);
				color: var(--text-dark);
			}
			main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
		</style>
	</head>
	<body>
		<nav style="background: #fff; padding: 1rem; border-bottom: 1px solid #ddd;">
			<div style="max-width: 1000px; margin: 0 auto; font-weight: bold; font-size: 1.5rem;">
				<a href="/" style="text-decoration: none; color: var(--primary);">Astra Engine</a>
			</div>
		</nav>

		<main>
			<slot /> </main>

		<footer style="text-align: center; padding: 2rem; color: #666; font-size: 0.9rem;">
			<p>&copy; {new Date().getFullYear()} Astra Industrial Solutions. All rights reserved.</p>
		</footer>
	</body>
</html>
